# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5433/ecomsaas"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"

# Environment
NODE_ENV="development"

# CORS Origins (comma separated)
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# Swagger UI Credentials (change these in production!)
SWAGGER_USER="admin"
SWAGGER_PASS="changeme"

# Trusted Proxy IPs (comma separated) - for proper client IP detection behind reverse proxy
# Default: 127.0.0.1,::1 (localhost only)
TRUSTED_PROXIES="127.0.0.1,::1"